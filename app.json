{
  "expo": {
    "name": "Zakat Calculator",
    "slug": "zakat-calculator",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "zakatcalculator",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#0A2E31"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zakatcalculator.uae"
    },
    "android": {
      "package": "com.zakatcalculator.uae",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0D3B3E",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "privacyPolicyUrl": "https://sobaantahir97.github.io/zakat-calculator/PRIVACY_POLICY"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "574185ae-8851-4096-aa7d-da457042b965"
      }
    },
    "owner": "sobaantahir97",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/574185ae-8851-4096-aa7d-da457042b965"
    }
  }
}
